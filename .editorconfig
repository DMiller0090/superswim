root = true

[*]
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true
end_of_line = lf

[*.py]
indent_style = space
indent_size = 4
max_line_length = 100

[*.{toml,json,yml,yaml}]
indent_style = space
indent_size = 2

[*.md]
# Markdown can use trailing whitespace for hard line breaks.
trim_trailing_whitespace = false

[Makefile]
indent_style = tab
